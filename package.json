{
    "name": "i2p-pseudocode",
    "displayName": "I2P Pseudocode",
    "description": "Syntax highlighting for Intro to Programming (I2P) pseudocode.",
    "version": "0.0.1",
    "publisher": "ciioprof0",
    "repository": {
        "type": "git",
        "url": "https://github.com/i2p-hub/i2p-pseudocode.git"
    },
    "engines": {
        "vscode": "^1.25.0"
    },
    "categories": [
        "Programming Languages",
        "Education"
    ],
    "contributes": {
        "languages": [
            {
                "id": "i2p-pseudocode",
                "aliases": [
                    "I2P Pseudocode",
                    "i2p-pseudocode",
                    "pseudocode"
                ],
                "extensions": [
                    ".i2p",
                    ".pseudo",
                    ".pseudocode",
                    ".psc"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "i2p-pseudocode",
                "scopeName": "source.pseudocode",
                "path": "./syntaxes/i2p-pseudo.tmLanguage.json"
            }
        ]
    }
}